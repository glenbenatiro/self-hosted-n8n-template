# Copy this file to .env and modify the values for your setup.
# IMPORTANT: Dollar signs ($) in passwords must be escaped as $$.

ACME_EMAIL=your_email@example.com
TRAEFIK_DASHBOARD_DOMAIN=traefik.example.com

# Generate with: htpasswd -nB username
# Escape any $ as $$
TRAEFIK_BASIC_AUTH_USER_PASS=username:hashed_password
