# Copy this file to .env and fill in your values.

# NOTE: the ACME (Let's Encrypt) contact email is set directly in traefik.yml — Traefik does
# NOT read environment variables from its static config, so there is no ACME_EMAIL here.

# Only needed if you switch to the DNS-01 challenge (e.g. behind Cloudflare — see traefik.yml).
# A Cloudflare API token scoped to Zone:Read + DNS:Edit on your zone(s).
# CF_DNS_API_TOKEN=your_cloudflare_dns_api_token
